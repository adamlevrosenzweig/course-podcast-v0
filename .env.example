# API keys
ANTHROPIC_API_KEY=sk-ant-...
ELEVENLABS_API_KEY=sk_...
ELEVENLABS_VOICE_ID=E393dkE75hqtz1LO2aEJ

# Server
PORT=3000
BASE_URL=https://your-app.up.railway.app

# Persistent storage (Railway Volume)
# Set DATA_DIR and AUDIO_DIR to paths inside your Railway Volume mount point.
# On Railway: add a Volume mounted at /data, then set these two vars.
# Locally: leave unset (defaults to ./data and ./audio beside server.js).
DATA_DIR=/data
AUDIO_DIR=/data/audio
