# API keys
ANTHROPIC_API_KEY=sk-ant-...
ELEVENLABS_API_KEY=sk_...
ELEVENLABS_VOICE_ID=E393dkE75hqtz1LO2aEJ

# Server
PORT=3000
BASE_URL=https://your-app.up.railway.app

# Persistent storage (Railway Volume)
# Add a Volume at /data in Railway dashboard, then set these.
# Leave unset locally — defaults to ./data and ./audio.
DATA_DIR=/data
AUDIO_DIR=/data/audio

# Auto-generation schedule (cron syntax, America/Los_Angeles timezone)
# Default: 7 AM PT daily. Remove this line to use the default.
CRON_SCHEDULE=0 7 * * *
